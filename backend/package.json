{
  "name": "power-monitor-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Node-RED backend for Siemens S7-1500 (S7 / ISO-on-TCP) — bridges PLC data to HTTP for the power-monitor frontend",
  "scripts": {
    "postinstall": "npm install --prefix ./node-red-data",
    "start": "node-red --userDir ./node-red-data",
    "start:verbose": "DEBUG=node-red:* node-red --userDir ./node-red-data"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "node-red": "^4.0.0",
    "node-red-contrib-s7": "^3.1.3",
    "node-red-dashboard": "^3.6.6"
  }
}
