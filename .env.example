#
# Local dev configuration for power-monitor-frontend
#
# Mock mode is enabled by default. To connect to a real backend, set
# VITE_USE_MOCK=false and provide VITE_API_BASE_URL.
#

# Use mock in-browser API implementations (true/false)
# For PLC / Node-RED: set false and point VITE_API_BASE_URL at Node-RED (port 1880).
VITE_USE_MOCK=true

# Backend base URL. Node-RED in repo `backend/` listens on 1880 by default.
# Example when the Vite app runs separately: http://127.0.0.1:1880
# Leave empty only if you proxy /api to Node-RED from the same origin.
VITE_API_BASE_URL=

